# Copy to release.env and fill with real production values outside git.
# Do not commit release.env, keystores, passwords, merchant secrets, or backend admin tokens.

export QUANTTRADING_PRODUCTION_API_BASE_URL="https://api.example.com/"
export QUANTTRADING_PRIVACY_POLICY_URL="https://example.com/privacy"
export QUANTTRADING_TERMS_URL="https://example.com/terms"
export QUANTTRADING_DATA_DISCLAIMER_URL="https://example.com/data-disclaimer"
export QUANTTRADING_SUPPORT_EMAIL="support@example.com"

export QUANTTRADING_RELEASE_KEYSTORE="/secure/path/quanttrading-upload.jks"
export QUANTTRADING_RELEASE_STORE_PASSWORD="replace-with-store-password"
export QUANTTRADING_RELEASE_KEY_ALIAS="quanttrading-upload"
export QUANTTRADING_RELEASE_KEY_PASSWORD="replace-with-key-password"

# Backend deployment secrets. Keep these in the deployment provider's secret store.
export QUANTTRADING_DB_PATH="/data/quanttrading.db"
export QUANTTRADING_PAYMENT_CALLBACK_SECRET="replace-with-strong-payment-callback-secret"
export QUANTTRADING_REQUIRE_CALLBACK_SIGNATURE="1"
export QUANTTRADING_ADMIN_TOKEN="replace-with-strong-admin-token"
