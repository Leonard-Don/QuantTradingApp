# Copy to release.env and fill with real production values outside git.
# Do not commit release.env, keystores, passwords, merchant secrets, or backend admin tokens.

export TIANXIAN_PRODUCTION_API_BASE_URL="https://api.example.com/"
export TIANXIAN_PRIVACY_POLICY_URL="https://example.com/privacy"
export TIANXIAN_TERMS_URL="https://example.com/terms"
export TIANXIAN_DATA_DISCLAIMER_URL="https://example.com/data-disclaimer"
export TIANXIAN_SUPPORT_EMAIL="support@example.com"

export TIANXIAN_RELEASE_KEYSTORE="/secure/path/tianxian-upload.jks"
export TIANXIAN_RELEASE_STORE_PASSWORD="replace-with-store-password"
export TIANXIAN_RELEASE_KEY_ALIAS="tianxian-upload"
export TIANXIAN_RELEASE_KEY_PASSWORD="replace-with-key-password"

# Backend deployment secrets. Keep these in the deployment provider's secret store.
export TIANXIAN_DB_PATH="/data/tianxian.db"
export TIANXIAN_PAYMENT_CALLBACK_SECRET="replace-with-strong-payment-callback-secret"
export TIANXIAN_REQUIRE_CALLBACK_SIGNATURE="1"
export TIANXIAN_ADMIN_TOKEN="replace-with-strong-admin-token"
